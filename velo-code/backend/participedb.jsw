/**
 * Get pending registrations for batch sync
 * @param {number} limit - Max records to return
 * @returns {Promise<Array<Object>>} Pending registrations
 */
export async function getPendingRegistrations(limit = 50) {
    try {
        const results = await wixData.query('Registros')
            .eq('syncStatus', 'pending')
            .limit(limit)
            .find();

        return results.items || [];

    } catch (error) {
        console.error('Failed to get pending registrations:', error);
        return [];
    }
}

/**
 * Update sync status for a registration
 * @param {string} registrationId - Registration ID
 * @param {string} status - New status ('synced', 'failed')
 * @param {Object} metadata - Additional metadata
 * @returns {Promise<Object>} Update result
 */
export async function updateSyncStatus(registrationId, status, metadata = {}) {
    try {
        const updateData = {
            syncStatus: status,
            lastSyncAt: new Date(),
            syncAttempts: { $inc: 1 },
            ...metadata,
            _updatedDate: new Date()
        };

        const result = await wixData.update('Registros', updateData);
        console.log(`Sync status updated to ${status} for registration ${registrationId}`);

        return result;

    } catch (error) {
        console.error('Failed to update sync status:', error);
        throw error;
    }
